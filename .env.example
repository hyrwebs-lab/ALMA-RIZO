# ─── Base de datos ───────────────────────────────────────────────
# EN LOCAL: si dejas esto vacío, usa un archivo local (file:./data/almarizo.db). No hace falta nada.
# EN PRODUCCIÓN (Vercel): crea una base de datos gratuita en Turso (https://turso.tech)
#   y pega aquí la URL (libsql://...) y el token. Ejecuta: turso db create alma-rizo
DATABASE_URL=
DATABASE_AUTH_TOKEN=

# ─── Contraseñas del panel /admin  (IMPORTANTE: cambiar en producción) ──
# Si se dejan vacías, se usan las por defecto (admin / alma / equipo).
# Se aplican solo la primera vez que se crea la base de datos.
ADMIN_PASSWORD=
OWNER_PASSWORD=
WORKER_PASSWORD=
